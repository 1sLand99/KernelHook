# Kbuild for KernelHook kernel module test harness (Approach A)
#
# Usage:
#   make -C /lib/modules/$(uname -r)/build M=$(pwd) modules
#   make -C /path/to/kernel M=$(pwd) ARCH=arm64 CROSS_COMPILE=aarch64-linux-gnu- modules
#
# For Android kernel headers:
#   make -C /path/to/android-kernel/out/common M=$(pwd) ARCH=arm64 \
#        CROSS_COMPILE=aarch64-linux-gnu- modules

obj-m := kh_test.o

# KernelHook project root
KH_ROOT := $(src)/../..

# Test module sources
kh_test-y := test_main.o test_hook_kernel.o kmod_mem_ops.o kmod_log.o

# KernelHook core sources (kernel path: no __USERSPACE__)
kh_test-y += $(KH_ROOT)/src/hmem.o
kh_test-y += $(KH_ROOT)/src/ksyms.o
kh_test-y += $(KH_ROOT)/src/arch/arm64/inline.o
kh_test-y += $(KH_ROOT)/src/arch/arm64/transit.o
kh_test-y += $(KH_ROOT)/src/arch/arm64/insn.o
kh_test-y += $(KH_ROOT)/src/arch/arm64/pgtable.o

# Include paths
ccflags-y += -I$(KH_ROOT)/include
ccflags-y += -I$(KH_ROOT)/include/arch/arm64
