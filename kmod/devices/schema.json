{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "KernelHook device profile",
  "type": "object",
  "required": ["identity", "match", "modversions", "struct_module", "vermagic"],
  "properties": {
    "identity": {
      "type": "object",
      "required": ["name", "arch"],
      "properties": {
        "name":        {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "description": {"type": "string"},
        "arch":        {"type": "string", "enum": ["aarch64"]}
      }
    },
    "match": {
      "type": "object",
      "required": ["kernelrelease"],
      "properties": {
        "kernelrelease": {"type": "string"}
      }
    },
    "modversions": {
      "type": "object",
      "required": ["module_layout", "_printk", "memcpy", "memset"],
      "patternProperties": {
        "^[a-zA-Z_][a-zA-Z0-9_]*$": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{1,8}$"
        }
      }
    },
    "struct_module": {
      "type": "object",
      "required": ["this_module_size", "module_init_offset", "module_exit_offset"],
      "patternProperties": {
        "^[a-z_]+$": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{1,8}$"
        }
      }
    },
    "vermagic": {
      "type": "object",
      "required": ["string"],
      "properties": {
        "string": {"type": "string", "minLength": 1}
      }
    },
    "provenance": {
      "type": "object",
      "properties": {
        "verified":        {"type": "boolean"},
        "source_module":   {"type": "string"},
        "extracted_by":    {"type": "string"},
        "extracted_at":    {"type": "string"},
        "contributed_by":  {"type": "string"}
      }
    }
  }
}
